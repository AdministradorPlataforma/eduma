{
    "name": "eduma/sistema-gestion",
    "description": "Sistema de Gestión Académica EDUMA",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Eduma Dev Team"
        }
    ],
    "require": {
        "php": "^7.4",
        "chillerlan/php-qrcode": "^5.0",
        "dompdf/dompdf": "*",
        "phpoffice/phpspreadsheet": "^1.30"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Config\\": "config/"
        }
    },
    "config": {
        "optimize-autoloader": false,
        "sort-packages": true,
        "platform-check": false,
        "exclude-from-classmap": [
            "vendor/dompdf/dompdf/lib/"
        ]
    }
}