# Configuración de Base de Datos
DB_HOST=localhost
DB_NAME=eduma
DB_USER=root
DB_PASSWORD=

# Configuración de la Aplicación
APP_NAME=EDUMA
APP_ENV=production
APP_DEBUG=false
BASE_URL=http://localhost/eduma/

# Configuración de Moodle API
MOODLE_URL=https://moodle.example.com/webservice/rest/server.php
MOODLE_TOKEN=
MOODLE_VERIFY_SSL=true
MOODLE_TIMEOUT=120

# Configuración de Sincronización Optimizada (v3.0)
MOODLE_PARALLEL_REQUESTS=5
MOODLE_BULK_INSERT_SIZE=500
MOODLE_SYNC_LOG_LEVEL=error

# Configuración de Sesión
SESSION_TIMEOUT=3600
SESSION_NAME=EDUMA_SESSION

# Configuración de Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=Strict

# Configuración de Seguridad
# IMPORTANTE: En producción, usar variables de entorno del sistema en lugar de este archivo
# para secretos sensibles (MOODLE_TOKEN, APP_SECRET, DB_PASSWORD)
APP_SECRET=
CSRF_TOKEN_NAME=csrf_token
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_LOCKOUT_TIME=900

# Zona Horaria
TIMEZONE=America/Asuncion
